<h1>Edite o seu livro</h1>

<form action="/books/updatebook" method="POST" class="form">
<input type="hidden" name="id" value="{{book.id}}">

<div class="form-control">
    <label for="titlle">Titulo:</label>
    <input type="text" name="title" placeholder="digite o titulo" value="{{book.title}}">
</div>
<div class="form-control">
    <label for="pageqti">Numero de página</label>
    <input type="number" name="pageqti" placeholder="Quantas páginas tem o livro?" value="{{book.pageqti}}">
</div>
<input type="submit" value="Editar">


</form>