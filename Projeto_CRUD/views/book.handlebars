<div id="book-page">

    <a href="/books">VOLTAR</a>
    <div class="container">
        <h1>{{book.title}}</h1>
        <p>Este livro tem {{book.pageqti}} páginas</p>
        <div class="action">
            <a href="/book/edit/{{book.id}}">Editar</a>
            <form action="/books/remove/{{book.id}}" method="POST">
            <input type="submit" value="Remover">
            </form>
        </div>
    </div>
</div>